spring.application.name=backend

# CORS (change to your frontend URL when deploying)
cors.allowed-origin=http://localhost:5173


# Database Settings
spring.datasource.url=jdbc:mysql://localhost:3306/online_course_platform?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=ocp_user
spring.datasource.password=YOUR_DB_PASSWORD_HERE
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA settings
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.defer-datasource-initialization=true
spring.sql.init.mode=always

# JWT Settings
jwt.secret=${YOUR_JWT_SECRET_HERE}
jwt.expiration=86400000  

# ECPay Settings (Sandbox/Test)
# ECPay sandbox MerchantID (public test value)
ecpay.merchant-id=2000132
ecpay.hash-key=YOUR_ECPAY_HASH_KEY
ecpay.hash-iv=YOUR_ECPAY_HASH_IV
ecpay.payment-action-url=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# Your Ngrok URL (run: ngrok http 8080)
ecpay.backend-url=https://YOUR_NGROK_URL.ngrok-free.dev

# Email Settings (Gmail SMTP)
# To get a Gmail App Password:
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate a new app password for "Mail"
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=YOUR_EMAIL@gmail.com
spring.mail.password=YOUR_GMAIL_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

spring.servlet.multipart.max-file-size=10MB

# OpenRouter AI API
# Get your API key at https://openrouter.ai/keys
openrouter.api.key=YOUR_OPENROUTER_API_KEY
